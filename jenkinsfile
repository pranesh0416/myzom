pipeline {
    agent any
    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {

        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git 'https://github.com/pranesh0416/myzom.git'
            }
        }

        stage("Sonarqube Analysis") {
            steps {
                withSonarQubeEnv('sqube') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=zomato \
                    -Dsonar.projectKey=zomato '''
                }
            }
        }

        stage("Code Quality Gate") {
            steps {
                script {
                    waitForQualityGate abortPipeline: false, credentialsId: 'Sonar-token'
                }
            }
        }

        stage("Install NPM Dependencies") {
            steps {
                sh "npm install"
            }
        }

        stage("Build Docker Image") {
            steps {
                sh "docker build -t zomato ."
            }
        }

        stage("Tag & Push to DockerHub") {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker') {
                        sh "docker tag zomato pollyshelby/zomato:${BUILD_NUMBER}"
                        sh "docker push pollyshelby/zomato:${BUILD_NUMBER}"
                    }
                }
            }
        }

        stage("Update Image Tag") {
            steps {
                sh "sed -i 's|pollyshelby/zomato:latest|pollyshelby/zomato:${BUILD_NUMBER}|g' Kubernetes/deployment.yaml"
            }
        }

        stage("Deploy to Kubernetes") {
            steps {
                withCredentials([
                    string(credentialsId: 'access key', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'secret key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    withKubeConfig([credentialsId: 'k8s']) {
                        sh 'aws eks update-kubeconfig --region ap-south-1 --name jenkins-cluster'
                        sh 'kubectl apply -f Kubernetes/deployment.yaml'
                        sh 'kubectl apply -f Kubernetes/service.yaml'
                    }
                }
            }
        }

    }
}
